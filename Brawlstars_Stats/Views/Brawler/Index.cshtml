@model IEnumerable<Brawlstars_Stats.Models.Brawler>

@{
    ViewData["Title"] = "Deine Brawler";
}

<div class="page-header animate-in">
    <h2><span class="header-icon">🏆</span> Brawler Übersicht</h2>
    <a asp-action="Create" class="btn-brawl-primary">
        <i class="bi bi-plus-lg"></i> Neuen Brawler hinzufügen
    </a>
</div>

<div class="table-brawl-wrapper animate-in animate-in-delay-1">
    <table class="table-brawl">
        <thead>
            <tr>
                <th>Name</th>
                <th>HP</th>
                <th>Angriff</th>
                <th>Typ / Rolle</th>
                <th>Seltenheit</th>
                <th>Skin</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var brawler in Model)
            {
                <tr>
                    <td><span class="brawler-name">@brawler.Name</span></td>
                    <td><span class="badge-brawl badge-brawl-hp">❤️ @brawler.Hp</span></td>
                    <td><span class="badge-brawl badge-brawl-atk">⚔️ @brawler.Ang</span></td>
                    <td><span class="badge-brawl badge-brawl-info">@brawler.Typ</span></td>
                    <td><span class="badge-brawl badge-brawl-warning">@brawler.Seltenheit</span></td>
                    <td>
                        @if (!string.IsNullOrEmpty(brawler.Skin))
                        {
                            <span class="badge-brawl badge-brawl-neutral">@brawler.Skin</span>
                        }
                        else
                        {
                            <span class="badge-brawl badge-brawl-neutral">Standard</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>