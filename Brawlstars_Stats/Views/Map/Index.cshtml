@model IEnumerable<Brawlstars_Stats.Models.Map>

@{
    ViewData["Title"] = "Alle Maps";
}

<div class="page-header animate-in">
    <h2><span class="header-icon">🗺️</span> Brawl Stars Maps</h2>
</div>

<div class="table-brawl-wrapper animate-in animate-in-delay-1">
    <table class="table-brawl">
        <thead>
            <tr>
                <th>Bezeichnung</th>
                <th>Empfohlener Brawler-Typ</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var map in Model)
            {
                <tr>
                    <td><strong>@map.MapBezeichnung</strong></td>
                    <td><span class="badge-brawl badge-brawl-info">@map.EmpfohlenerTyp</span></td>
                </tr>
            }
        </tbody>
    </table>
</div>