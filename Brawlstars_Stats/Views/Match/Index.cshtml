@model IEnumerable<Brawlstars_Stats.Models.Match>

@{
    ViewData["Title"] = "Match Historie";
}

<div class="container animate-in">
    <div class="page-header">
        <h2 class="fw-bold mb-0"><span class="header-icon">📊</span> Deine Match Historie</h2>
        <a asp-action="Create" class="btn-brawl-primary">
            <i class="bi bi-plus-lg"></i> Neues Match
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <span class="empty-icon">🎮</span>
            <h4>Noch leer!</h4>
            <p>Schnapp dir dein Handy, spiel eine Runde und tracke hier dein erstes Match.</p>
        </div>
    }
    else
    {
        <div class="table-brawl-wrapper animate-in-delay-1">
            <table class="table-brawl">
                <thead>
                    <tr>
                        <th class="text-start ps-4">Spieler</th>
                        <th>Brawler</th>
                        <th>Modus / Map</th>
                        <th>Kills / Tode</th>
                        <th>Schaden</th>
                        <th>Platz</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var match in Model)
                    {
                        var werte = match.Wertes.FirstOrDefault();

                        <tr>
                            <td class="text-start ps-4">
                                <span class="badge-brawl badge-brawl-tag">@match.Kuerzel</span>
                            </td>

                            <td class="brawler-name">
                                @match.Brawler?.Name
                            </td>

                            <td>
                                <div class="mode-name">@match.Modi?.Bezeichnung</div>
                                <div class="map-name">@match.Map?.MapBezeichnung</div>
                            </td>

                            <td>
                                <span class="badge-brawl badge-brawl-kills">
                                    @(werte?.Kills ?? 0)
                                </span>
                                <span class="stat-separator">/</span>
                                <span class="badge-brawl badge-brawl-deaths">
                                    @(werte?.Tode ?? 0)
                                </span>
                            </td>

                            <td class="stat-damage">
                                ⚔️ @(werte?.Schaden != null ? werte.Schaden.Value.ToString("N0") : "0")
                            </td>

                            <td>
                                @if (werte?.Platz != null)
                                {
                                    <span class="stat-placement">🏆 @werte.Platz.</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>