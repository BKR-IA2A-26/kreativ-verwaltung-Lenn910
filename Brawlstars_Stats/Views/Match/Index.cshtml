@model IEnumerable<Brawlstars_Stats.Models.Match>

@{
    ViewData["Title"] = "Match Historie";
}

<div class="container animate-in">
    <div class="page-header">
        <h2 class="fw-bold mb-0"><span class="header-icon">📊</span> Deine Match Historie</h2>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert" style="background: rgba(0, 230, 118, 0.15); border-color: rgba(0, 230, 118, 0.3); color: var(--accent-success);">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert" style="background: rgba(255, 71, 87, 0.15); border-color: rgba(255, 71, 87, 0.3); color: var(--accent-danger);">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- API Sync Leiste -->
    <div class="form-card mb-4 p-3 animate-in-delay-1">
        <form asp-action="Sync" method="get" class="form-brawl row g-2 align-items-center">
            <div class="col-auto">
                <label class="col-form-label text-muted fw-bold" style="font-size:0.85rem;"><i class="bi bi-tag-fill text-primary"></i> SPIELER-TAG:</label>
            </div>
            <div class="col-sm-3">
                <input type="text" name="playerTag" class="form-control" value="#2L9PRRJ28" placeholder="#..." required />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn-brawl-primary" id="btnSync">
                    <i class="bi bi-arrow-repeat"></i> Live Synchronisieren
                </button>
            </div>
            <div class="col text-end">
                <a asp-action="Create" class="btn-brawl-success">
                    <i class="bi bi-plus-lg"></i> Manuell eintragen
                </a>
            </div>
        </form>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <span class="empty-icon">🎮</span>
            <h4>Noch leer!</h4>
            <p>Trage deinen Spieler-Tag ein und klicke auf Synchronisieren, oder erstelle manuell dein erstes Match.</p>
        </div>
    }
    else
    {
        <div class="table-brawl-wrapper animate-in-delay-1">
            <table class="table-brawl">
                <thead>
                    <tr>
                        <th class="text-start ps-4">Spieler</th>
                        <th>Brawler</th>
                        <th>Modus / Map</th>
                        <th>Kills / Tode</th>
                        <th>Schaden</th>
                        <th>Platz</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var match in Model)
                    {
                        var werte = match.Wertes.FirstOrDefault();

                        <tr>
                            <td class="text-start ps-4">
                                <span class="badge-brawl badge-brawl-tag">@match.Kuerzel</span>
                            </td>

                            <td class="brawler-name">
                                @match.Brawler?.Name
                            </td>

                            <td>
                                <div class="mode-name">@match.Modi?.Bezeichnung</div>
                                <div class="map-name">@match.Map?.MapBezeichnung</div>
                            </td>

                            <td>
                                <span class="badge-brawl badge-brawl-kills">
                                    @(werte?.Kills ?? 0)
                                </span>
                                <span class="stat-separator">/</span>
                                <span class="badge-brawl badge-brawl-deaths">
                                    @(werte?.Tode ?? 0)
                                </span>
                            </td>

                            <td class="stat-damage">
                                ⚔️ @(werte?.Schaden != null ? werte.Schaden.Value.ToString("N0") : "0")
                            </td>

                            <td>
                                @if (werte?.Platz != null)
                                {
                                    <span class="stat-placement">🏆 @werte.Platz.</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('form').submit(function() {
                var btn = $('#btnSync');
                btn.prop('disabled', true);
                btn.html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Lade Spiele...');
            });
        });
    </script>
}