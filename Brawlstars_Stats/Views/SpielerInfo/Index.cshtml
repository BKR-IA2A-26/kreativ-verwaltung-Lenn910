@model IEnumerable<Brawlstars_Stats.Models.SpielerInfo>

@{
    ViewData["Title"] = "Spieler Profile";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Spieler Profile</h1>
        <a asp-action="Create" class="btn btn-primary">Neuen Spieler registrieren</a>
    </div>

    <table class="table table-striped table-hover table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Kürzel (Tag)</th>
                <th>Spieler / Attribut</th>
                <th>Gesamt-Kills</th>
                <th>Gesamt-Tode</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var spieler in Model)
            {
                <tr>
                    <td><code>@spieler.Kuerzel</code></td>
                    <td><strong>@spieler.Attribute</strong></td>
                    <td>@spieler.GesamteKills</td>
                    <td>@spieler.GesamteTode</td>
                </tr>
            }
        </tbody>
    </table>
</div>