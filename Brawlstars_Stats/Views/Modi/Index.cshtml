@model IEnumerable<Brawlstars_Stats.Models.Modi>

@{
    ViewData["Title"] = "Spielmodi";
}

<div class="page-header animate-in">
    <h2><span class="header-icon">⚡</span> Brawl Stars Modi</h2>
    <a asp-action="Create" class="btn-brawl-primary">
        <i class="bi bi-plus-lg"></i> Neuen Modus
    </a>
</div>

<div class="table-brawl-wrapper animate-in animate-in-delay-1">
    <table class="table-brawl">
        <thead>
            <tr>
                <th>Bezeichnung</th>
                <th>Team-Größe</th>
                <th>Spieler Insg.</th>
                <th>Gift-Wolke?</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var modus in Model)
            {
                <tr>
                    <td><strong>@modus.Bezeichnung</strong></td>
                    <td><span class="badge-brawl badge-brawl-neutral">@modus.TeamGroesse</span></td> @* Tipp: Falls EF Core es anders benannt hat, hier anpassen *@
                    <td><span class="badge-brawl badge-brawl-neutral">@modus.SpielerInsg</span></td>
                    <td>
                        @if (modus.Gift == true)
                        {
                            <span class="gift-yes"><i class="bi bi-check-circle-fill"></i> Ja</span>
                        }
                        else
                        {
                            <span class="gift-no"><i class="bi bi-x-circle"></i> Nein</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>